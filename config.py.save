# Traffic capture duration in seconds
CAPTURE_DURATION = 120

# Output directories
DATA_DIR    = "data/"
REPORTS_DIR = "reports/"

# Ports flagged as risky if found open
RISKY_PORTS = {
    21:   "FTP — plaintext file transfer",
    23:   "Telnet — plaintext remote access",
    80:   "HTTP — unencrypted web traffic",
    445:  "SMB — Windows file sharing, exploit target",
    3389: "RDP — Remote Desktop, brute-force target",
    5900: "VNC — often unencrypted remote desktop",
    8080: "HTTP-alt — often misconfigured admin panel",
}

