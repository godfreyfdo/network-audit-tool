    "ftp_detected":     {"score": 7.5, "label": "High"},
    "rdp_open":         {"score": 8.8, "label": "High"},
    "http_plaintext":   {"score": 5.3, "label": "Medium"},
    "smb_open":         {"score": 7.5, "label": "High"},
    "vnc_open":         {"score": 8.0, "label": "High"},
    "arp_anomaly":      {"score": 8.2, "label": "High"},
    "no_reverse_dns":   {"score": 2.5, "label": "Low"},
    "risky_port_open":  {"score": 5.0, "label": "Medium"},
